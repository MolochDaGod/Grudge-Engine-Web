# Grudge Engine Web — Environment Variables

# Server
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/grudge_engine

# Session
SESSION_SECRET=your-session-secret-here

# AI (Optional — for AI assistant and auto-rig)
OPENAI_API_KEY=

# Puter Cloud (Optional — for cloud save)
PUTER_AUTH_TOKEN=
PUTER_APP_ID=
