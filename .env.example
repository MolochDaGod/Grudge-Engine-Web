# Grudge Engine Web — Environment Variables

# Server
NODE_ENV=development
PORT=5000

# Database (PostgreSQL)
DATABASE_URL=postgresql://user:password@localhost:5432/grudge_engine

# Session
SESSION_SECRET=your-session-secret-here

# Storage Provider — "local" (default), "s3" (Railway Buckets / AWS / MinIO / R2)
STORAGE_PROVIDER=local

# S3-Compatible Storage (required when STORAGE_PROVIDER=s3)
# Railway Buckets auto-inject these when linked
BUCKET_NAME=
BUCKET_ENDPOINT=
BUCKET_ACCESS_KEY_ID=
BUCKET_SECRET_ACCESS_KEY=
BUCKET_REGION=us-east-1
# BUCKET_PRESIGN_TTL=3600

# AI (Optional — for AI assistant and auto-rig)
OPENAI_API_KEY=

# Puter Cloud (Optional — for cloud save)
PUTER_AUTH_TOKEN=
PUTER_APP_ID=
